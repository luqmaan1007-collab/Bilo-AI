# AGNES_API_KEY: Required for AGNES AI API completions.
# AI Studio automatically injects this at runtime from user secrets.
AGNES_API_KEY="YOUR_AGNES_API_KEY"

# GEMINI_API_KEY: Required for Gemini models, such as native image generation.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"


# CLAUDE_API_KEY: Required for Claude chat completions.
CLAUDE_API_KEY="YOUR_CLAUDE_API_KEY"

# GROK_API_KEY: Optional. If provided, Bilo AI calls official x.ai (Grok-2) API model directly.
GROK_API_KEY="YOUR_GROK_API_KEY"

# OPENAI_API_KEY: Required for OpenAI chat completions.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# OPENROUTER_API_KEY: Required for OpenRouter chat completions.
OPENROUTER_API_KEY=

# SMTP_HOST / SMTP_USER / SMTP_PASS: Optional. Setup real password reset emails via your custom SMTP provider (Gmail, Brevo, SendGrid, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# RESEND_API_KEY: Optional. Setup real password reset emails via Resend.
RESEND_API_KEY=
RESEND_FROM=

# TELNYX_API_KEY: Required for premium cloud Text-to-Speech (Grok 1.0 Leo Style)
TELNYX_API_KEY=

